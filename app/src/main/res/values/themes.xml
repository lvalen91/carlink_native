<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme -->
    <style name="Theme.CarlinkNative" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <!-- Fullscreen theme for main activity.
         windowFullscreen removed: it conflicts with per-mode decorFitsSystemWindows
         control in applyDisplayMode() and causes cold-start SystemUI visibility races.
         layoutInDisplayCutoutMode is set at runtime per DisplayMode instead of
         hard-coded here, so SYSTEM_UI_VISIBLE respects the cutout envelope while
         immersive modes extend into it. -->
    <style name="Theme.CarlinkNative.Fullscreen" parent="Theme.CarlinkNative">
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>
